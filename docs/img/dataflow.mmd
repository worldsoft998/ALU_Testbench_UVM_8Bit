flowchart LR
    subgraph Python["Python process"]
        AGENT["SB3 Policy<br/>PPO / DQN / A2C"]
        GYM["Gymnasium Env<br/>bridge_env.py"]
        BRIDGE_PY["uvm_bridge.py<br/>hdl_if @api class"]
    end
    subgraph VCS["Synopsys VCS"]
        PYHDLIF_SV["PyHDL-IF<br/>TLM FIFOs"]
        RLSEQ["alu_rl_sequence"]
        SQR["alu_sequencer"]
        DRV["alu_driver"]
        DUT["ALU DUT"]
        MON["alu_monitor"]
        SCB["alu_scoreboard"]
        COV["alu_coverage_collector"]
        BR["alu_rl_bridge"]
    end
    AGENT -- action --> GYM
    GYM  -- request --> BRIDGE_PY
    BRIDGE_PY -- TLM put --> PYHDLIF_SV
    PYHDLIF_SV --> RLSEQ --> SQR --> DRV --> DUT
    DUT --> MON --> SCB
    MON --> COV
    MON --> BR
    BR -- TLM put --> PYHDLIF_SV
    PYHDLIF_SV -- TLM get --> BRIDGE_PY
    BRIDGE_PY -- response --> GYM --> AGENT
